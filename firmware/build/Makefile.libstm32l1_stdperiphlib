

ifeq ($(LIBNAME)$(BINARY),)

LIBNAME = stm32l1stdperiphlib

SRC      = misc.c               stm32l1xx_exti.c            stm32l1xx_pwr.c
SRC     += stm32l1xx_adc.c      stm32l1xx_flash.c           stm32l1xx_rcc.c
SRC     += stm32l1xx_aes.c      stm32l1xx_flash_ramfunc.c   stm32l1xx_rtc.c
SRC     += stm32l1xx_aes_util.c stm32l1xx_fsmc.c            stm32l1xx_sdio.c
SRC     += stm32l1xx_comp.c     stm32l1xx_gpio.c            stm32l1xx_spi.c
SRC     += stm32l1xx_crc.c      stm32l1xx_i2c.c             stm32l1xx_syscfg.c
SRC     += stm32l1xx_dac.c      stm32l1xx_iwdg.c            stm32l1xx_tim.c
SRC     += stm32l1xx_dbgmcu.c   stm32l1xx_lcd.c             stm32l1xx_usart.c
