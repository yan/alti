SRC_DIR := stm32l1_stdperiphlib/Libraries/STM32L1xx_StdPeriph_Driver/src

## Custom assert macro lives in stm32l1xx_conf.h
USER_CPPFLAGS += -include stm32l1xx_conf.h

include build/include.mk

endif

STM32_PERIPH_DIR := stm32l1_stdperiphlib/Libraries/STM32L1xx_StdPeriph_Driver

CPPFLAGS   += -DSTM32_STDPERIPH_LIB
